# === 데이터 소스 경로 (클론 후 각자 환경에 맞게 필수 설정) ===
# 미설정 시 config.py 기본값(개발자 PC 경로)이 쓰여 동작하지 않습니다.
# KAKAO_BASE_DIR=C:/path/to/kakao_logs/llm/rooms
# INGAME_BASE_DIR=C:/path/to/playwright_chat_reader/output

RUN_INTERVAL_SECONDS=300
CONTEXT_WINDOW_MINUTES=10
NEW_WINDOW_MINUTES=5
DB_MESSAGE_RETENTION_MINUTES=10
LOOP_ENABLED=1
# 스냅샷 보관 run 수 (디스크 사용량과 비례 — 환경에 맞게 조정).
SNAPSHOT_RETENTION_RUNS=288

LOCAL_LLM_ENDPOINT=http://localhost:8080
LOCAL_LLM_MODEL=Qwen3.5-9B
#LLM_PROVIDER=local
LLM_JUDGE_ENABLED=1
LLM_TIMEOUT_SEC=180

LLM_THINKING_MODE=1
LLM_FORCE_JSON=1
LLM_SHOW_THINKING_OUTPUT=1
LLM_THINKING_STATUS_OUTPUT=1
LLM_DISPLAY_RAW_WITH_THINKING=0
LLM_STORE_RAW_WITH_THINKING=1

# (선택) 샘플링 파라미터 — 미설정 시 config.py 기본값. 환경/모델에 맞게 조정.
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.9
# LLM_TOP_K=40
# LLM_PRESENCE_PENALTY=0.0
LLM_RESPONSE_GREEN_OUTPUT=1

# 하이브리드: 1차=로컬, 2차 검증=OpenAI (로컬 alert 시에만 OpenAI 호출)
LLM_PROVIDER=local
VERIFY_ENABLED=1
VERIFY_PROVIDER=openai
OPENAI_API_KEY=<your-OPENAI_API_KEY-here>
# 2차 검증에 쓸 OpenAI 모델 (실제 사용 가능한 모델명으로 설정). 미설정 시 config 기본값.
# OPENAI_MODEL=gpt-5.4
# OPENAI_ENDPOINT=https://api.openai.com
# Optional OpenAI-only overrides. Local LLM_* sampling values are not reused for OpenAI.
# OPENAI_MAX_COMPLETION_TOKENS=4096
# OPENAI_TEMPERATURE=
# OPENAI_TOP_P=
# OPENAI_PRESENCE_PENALTY=
# Claude test:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_ENDPOINT=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_MAX_TOKENS=4096

SLACK_WEBHOOK_URL=<your-SLACK_WEBHOOK_URL-here>
SLACK_APP_TOKEN=<your-SLACK_APP_TOKEN-here>
SLACK_ALERT_ENABLED=1
# 1이면 main.py / llm_replay / run_prompt_samples의 false 결과도 TEMP/FALSE로 발송
SLACK_NOTIFY_ALL=0
# 1이면 llm_replay / run_prompt_samples 같은 테스트성 실행의 Slack 발송 허용
SLACK_NOTIFY_TESTS=0
# 1이면 main false/TEMP, llm_replay, run_prompt_samples 알림을 임시로 SLACK_CHANNEL_A에 발송
SLACK_TEMP_TO_A=0
SLACK_INTERACTIONS_ENABLED=1
SLACK_SIGNING_SECRET=<your-SLACK_SIGNING_SECRET-here>
SLACK_INTERACTION_HOST=127.0.0.1
SLACK_INTERACTION_PORT=8787
SLACK_SNOOZE_MINUTES=10

# Bot Token 방식 (should_alert=true 시 chat.postMessage + thread evidence)
# 미설정 시 기존 Webhook 흐름 그대로 동작 (스레드 evidence 비활성).
SLACK_BOT_TOKEN=<your-SLACK_BOT_TOKEN-here>
SLACK_CHANNEL=<your-SLACK_CHANNEL-here>
SLACK_CHANNEL_A=
# A 채널(추가 전송) 발송 최소 고유 신고자 수(2차 confirmed 시). reload_config 대상.
SLACK_CHANNEL_A_MIN_REPORTERS=4
SLACK_EVIDENCE_MAX_PER_SOURCE=20
